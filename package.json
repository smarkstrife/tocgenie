{
  "name": "tocgenie",
  "version": "0.1.0",
  "description": "A CLI tool that generates a table of contents for markdown files in a git repository",
  "author": "Shikhar Srivastava",
  "license": "MIT",
  "main": "dist/cli.js",
  "files": [
    "dist"
  ],
  "bin": {
    "tocgenie": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "glob": "^11.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ]
  }
}
