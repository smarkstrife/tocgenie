{
  "name": "tocgenie",
  "version": "0.1.0",
  "description": "A CLI tool that generates a table of contents for markdown files in a git repository",
  "author": "Shikhar Srivastava",
  "license": "MIT",
  "keywords": [
    "markdown",
    "table-of-contents",
    "toc",
    "cli",
    "anchor",
    "github",
    "gitlab",
    "bitbucket",
    "documentation",
    "heading",
    "generator",
    "nodejs",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/smarkstrife/tocgenie.git"
  },
  "homepage": "https://github.com/smarkstrife/tocgenie#readme",
  "bugs": {
    "url": "https://github.com/smarkstrife/tocgenie/issues"
  },
  "main": "dist/cli.js",
  "files": [
    "dist"
  ],
  "bin": {
    "tocgenie": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "glob": "^11.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ]
  }
}
